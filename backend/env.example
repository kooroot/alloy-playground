# Copy to .env and fill in.

# Which network to boot with. Runtime-switchable (Phase 2+) via POST /api/network.
NETWORK=anvil

# Anvil (local) endpoints. `anvil --block-time 2` exposes both HTTP and WS on 8545.
ANVIL_HTTP_URL=http://127.0.0.1:8545
ANVIL_WS_URL=ws://127.0.0.1:8545

# Sepolia endpoints. WebSocket URL is REQUIRED for Phase 5 (event subscription).
# Most free Sepolia RPCs are HTTP-only — grab a WS-capable URL from
# Alchemy / Infura / QuickNode free tier.
SEPOLIA_HTTP_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
SEPOLIA_WS_URL=wss://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Only required when wallet mode = "local" (programmatic PrivateKeySigner).
# Anvil's default account #0 private key is below — works out of the box on anvil.
# Replace with a real key for Sepolia.
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# axum bind address.
BIND_ADDR=0.0.0.0:8080

# Log filter (RUST_LOG style). `info,alloy_prototype_backend=debug` is a good default.
RUST_LOG=info,alloy_prototype_backend=debug
